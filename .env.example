# ── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL (Neon u otro administrado), tanto en desarrollo como en producción.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Autenticación ────────────────────────────────────────────────────────────
# Obligatorio en producción. Generar con: openssl rand -base64 32
AUTH_SECRET=""

# ── URL pública de la app (para links en mensajes y retornos de Mercado Pago) ─
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Mercado Pago (Checkout Bricks) ───────────────────────────────────────────
# Sin claves, los pagos corren en modo simulado (se aprueban localmente).
# Credenciales en https://www.mercadopago.com.ar/developers/panel/app
# (usar las de prueba para desarrollo y las productivas en producción).
# MP_ACCESS_TOKEN="APP_USR-…"            # Access Token (backend)
# NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-…"  # Public Key (Payment Brick en el navegador)
# MP_WEBHOOK_SECRET=""                   # Clave secreta del webhook (panel → Webhooks)
# MP_CURRENCY="ARS"

# ── WhatsApp (Prompt 5) ──────────────────────────────────────────────────────
# "simulated" (default): loguea en consola y en el dashboard, no envía nada.
# "twilio": envío real vía Twilio API for WhatsApp.
WHATSAPP_PROVIDER="simulated"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Teléfono del centro para avisos de turnos nuevos/cancelados:
STAFF_WHATSAPP="+5491100000000"

# ── Cron de recordatorios ────────────────────────────────────────────────────
# Obligatorio en producción; Vercel Cron lo manda como Bearer token.
# CRON_SECRET=""

# ── Zona horaria del centro (para formateo en el cliente) ───────────────
NEXT_PUBLIC_CLINIC_TZ="America/Argentina/San_Juan"
