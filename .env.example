# ── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL (Neon u otro administrado), tanto en desarrollo como en producción.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Autenticación ────────────────────────────────────────────────────────────
# Obligatorio en producción. Generar con: openssl rand -base64 32
AUTH_SECRET=""

# ── URL pública de la app (para links en mensajes y retornos de Stripe) ─────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stripe (Prompt 4) ────────────────────────────────────────────────────────
# Sin claves, los pagos corren en modo simulado (se aprueban localmente).
# STRIPE_SECRET_KEY="sk_test_…"
# STRIPE_WEBHOOK_SECRET="whsec_…"   # del endpoint /api/payments/webhook
# STRIPE_CURRENCY="ars"

# ── WhatsApp (Prompt 5) ──────────────────────────────────────────────────────
# "simulated" (default): loguea en consola y en el dashboard, no envía nada.
# "twilio": envío real vía Twilio API for WhatsApp.
WHATSAPP_PROVIDER="simulated"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Teléfono del consultorio para avisos de turnos nuevos/cancelados:
STAFF_WHATSAPP="+5491100000000"

# ── Cron de recordatorios ────────────────────────────────────────────────────
# Obligatorio en producción; Vercel Cron lo manda como Bearer token.
# CRON_SECRET=""

# ── Zona horaria del consultorio (para formateo en el cliente) ───────────────
NEXT_PUBLIC_CLINIC_TZ="America/Argentina/Buenos_Aires"
